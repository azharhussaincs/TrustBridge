generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  password      String
  name          String
  role          String    @default("TEAM_MEMBER")
  teamId        String?
  isOnline      Boolean   @default(false)
  lastSeen      DateTime  @default(now())
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  
  // File relations
  sentFiles     File[]    @relation("SentFiles")
  receivedFiles File[]    @relation("ReceivedFiles")
}

model Team {
  id            String    @id @default(cuid())
  name          String
  leadId        String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}

model Message {
  id            String    @id @default(cuid())
  content       String
  isEncrypted   Boolean   @default(true)
  senderId      String
  receiverId    String
  fileId        String?
  read          Boolean   @default(false)
  readAt        DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}

model File {
  id            String    @id @default(cuid())
  filename      String
  path          String
  size          Int
  mimeType      String
  isEncrypted   Boolean   @default(true)
  senderId      String
  receiverId    String
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  
  // Relations
  sender        User      @relation("SentFiles", fields: [senderId], references: [id])
  receiver      User      @relation("ReceivedFiles", fields: [receiverId], references: [id])
}
